---
import '../styles/global.css';
import { Image } from 'astro:assets';
import contactImage from '../assets/img/foto-contacto-2.webp';

const navigation = [
  { label: 'Inicio', href: '/' },
  { label: 'Ilustraciones', href: '/illustration' },
  { label: 'Concept Art', href: '/concept-art' },
  { label: 'Editorial', href: '/editorial' },
  { label: 'Contacto', href: '/contact' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Contacto y redes sociales de la ilustradora: Instagram, Behance y correo electrónico para encargos y colaboraciones."
    />
    <meta name="robots" content="index, follow" />
    <title>Contacto | Portfolio de Moona</title>
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-[#231f20]/10 bg-[#fffaf2]/85 backdrop-blur-xl">
      <nav
        class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-5 px-5 py-5 text-center sm:px-8 lg:flex-row lg:text-left"
        aria-label="Navegación principal"
      >
        <a
          href="/"
          class="font-serif text-2xl font-black tracking-tight text-[#231f20] transition hover:text-[#d95c45]"
          aria-label="Ir al inicio"
        >
          Moona
        </a>
        <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-3 text-sm font-bold uppercase tracking-[0.16em] text-[#59433b]">
          {
            navigation.map((item) => (
              <li>
                <a
                  class="transition hover:text-[#d95c45] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]"
                  href={item.href}
                  aria-current={item.href === '/contact' ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main>
      <section class="mx-auto grid min-h-[calc(100vh-6rem)] max-w-7xl place-items-center px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="contact-title">
        <div class="grid w-full items-center gap-10 rounded-[2.5rem] border-3 border-[#231f20] bg-[#fffaf2]/80 p-6 shadow-[12px_12px_0_#231f20] sm:p-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-14 lg:p-12">
          <figure class="mx-auto flex w-full max-w-sm flex-col items-center text-center lg:mx-0 lg:items-start lg:text-left">
            <div class="aspect-square w-full overflow-hidden rounded-full border-4 border-[#231f20] bg-gradient-to-br from-[#ffad8f] via-[#f7d7ff] to-[#9bd5ff] p-4 shadow-[10px_10px_0_#ee8d73]">
              <Image
                src={contactImage}
                width={640}
                alt="Foto de perfil de Moona"
                class="h-full w-full rounded-full object-cover object-[50%_50%]"
                decoding="async"
              />
            </div>
            <figcaption class="mt-6">
              <strong class="font-serif text-3xl font-black text-[#231f20]">Moona</strong>
              <span class="mt-2 block text-sm font-black uppercase tracking-[0.22em] text-[#d95c45]">Ilustración y diseño gráfico</span>
            </figcaption>
          </figure>

          <article class="text-center lg:text-left">
            <p class="text-sm font-black uppercase tracking-[0.32em] text-[#d95c45]">Contacto</p>
            <h1 id="contact-title" class="mt-3 font-serif text-5xl font-black leading-[0.95] tracking-tight text-[#231f20] sm:text-6xl lg:text-7xl">
              Redes sociales y contacto
            </h1>
            <p class="mt-6 text-lg leading-8 text-[#59433b]">
              Para encargos, colaboraciones o consultas editoriales, puedes contactar por redes o enviar un correo desde Gmail, Hotmail, Outlook o cualquier cliente de email compatible.
            </p>

            <ul class="mt-9 grid gap-4 sm:grid-cols-3" aria-label="Redes sociales y correo electrónico">
              <li class="social-link">
                <a
                  href="https://www.instagram.com/moonadevalencia"
                  target="_blank"
                  rel="noreferrer"
                  class="group flex h-full flex-col items-center justify-center rounded-[1.6rem] border-3 border-[#231f20] bg-[#ffd36e] px-5 py-6 text-center shadow-[7px_7px_0_#231f20] transition duration-300 hover:-translate-y-2 hover:scale-105 hover:bg-[#ffad8f] hover:shadow-[11px_11px_0_#231f20] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]"
                  aria-label="Abrir Instagram en una nueva pestaña"
                >
                  <svg class="h-10 w-10 text-[#231f20] transition group-hover:rotate-6 group-hover:scale-110" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"></rect>
                    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"></circle>
                    <circle cx="17.5" cy="6.5" r="1.3" fill="currentColor"></circle>
                  </svg>
                  <span class="mt-4 font-serif text-2xl font-black text-[#231f20]">Instagram</span>
                  <span class="mt-1 text-sm font-bold text-[#59433b]">@moonadevalencia</span>
                </a>
              </li>

              <li class="social-link">
                <a
                  href="https://www.behance.net/moonadevalencia"
                  target="_blank"
                  rel="noreferrer"
                  class="group flex h-full flex-col items-center justify-center rounded-[1.6rem] border-3 border-[#231f20] bg-[#9bd5ff] px-5 py-6 text-center shadow-[7px_7px_0_#231f20] transition duration-300 hover:-translate-y-2 hover:scale-105 hover:bg-[#c4b5fd] hover:shadow-[11px_11px_0_#231f20] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]"
                  aria-label="Abrir Behance en una nueva pestaña"
                >
                  <svg class="h-10 w-10 text-[#231f20] transition group-hover:-rotate-6 group-hover:scale-110" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 6h6.2c2 0 3.3 1.1 3.3 2.8 0 1.1-.6 1.9-1.6 2.3 1.3.4 2.2 1.4 2.2 3 0 2.2-1.6 3.9-4.4 3.9H4V6z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
                    <path d="M6.5 10.7h3.1c.9 0 1.4-.4 1.4-1.2s-.5-1.2-1.4-1.2H6.5v2.4zM6.5 15.8h3.5c1 0 1.6-.5 1.6-1.4s-.6-1.4-1.6-1.4H6.5v2.8z" fill="currentColor"></path>
                    <path d="M16 8h5M15.5 13.8h6.2c-.2-2.2-1.4-3.5-3.2-3.5-2.1 0-3.5 1.6-3.5 4s1.5 4 3.7 4c1.4 0 2.5-.6 3-1.7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                  <span class="mt-4 font-serif text-2xl font-black text-[#231f20]">Behance</span>
                  <span class="mt-1 text-sm font-bold text-[#59433b]">moonadevalencia</span>
                </a>
              </li>

              <li class="social-link">
                <a
                  href="mailto:moonadevalencia@gmail.com?subject=Consulta%20desde%20el%20portfolio"
                  class="group flex h-full flex-col items-center justify-center rounded-[1.6rem] border-3 border-[#231f20] bg-[#f7d7ff] px-5 py-6 text-center shadow-[7px_7px_0_#231f20] transition duration-300 hover:-translate-y-2 hover:scale-105 hover:bg-[#84cc9b] hover:shadow-[11px_11px_0_#231f20] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]"
                  aria-label="Enviar correo electrónico"
                >
                  <svg class="h-10 w-10 text-[#231f20] transition group-hover:rotate-3 group-hover:scale-110" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="14" rx="3" stroke="currentColor" stroke-width="2"></rect>
                    <path d="M4.5 7.5 12 13l7.5-5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                  <span class="mt-4 font-serif text-2xl font-black text-[#231f20]">Email</span>
                  <span class="mt-1 text-sm font-bold text-[#59433b]">moonadevalencia<br />@gmail.com</span>
                </a>
              </li>
            </ul>
          </article>
        </div>
      </section>
    </main>

    <footer class="border-t border-[#231f20]/10 px-5 py-10 text-center text-sm text-[#59433b] sm:px-8">
      <p><strong class="text-[#231f20]">Moona</strong> · Portfolio de ilustración y diseño gráfico.</p>
      <p class="mt-2">© {new Date().getFullYear()} Moona. Todos los derechos reservados.</p>
    </footer>
  </body>
</html>
