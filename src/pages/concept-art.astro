---
import FloatingIllustrationGallery from '../components/FloatingIllustrationGallery.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import type { ImageMetadata } from 'astro';
import '../styles/global.css';

type ImageModule = { default: ImageMetadata };

const imageModules = import.meta.glob<ImageModule>('../assets/concept-art/*.{jpg,jpeg,png,webp,avif,gif,svg}', {
  eager: true,
});

const captionOverrides: Record<string, string> = {
  'Banshee 1': 'Diseño del personaje Banshee.',
  'Banshee 2': 'Exploración de variantes, poses y expresiones faciales del personaje Banshee.',
  'Lumo': 'Desarrollo del personaje Lumo para el libro "¿Qué hago con este enfado?".',
  'Noah': 'Desarrollo del personaje Noah para el libro "¿Qué hago con este enfado?".',
  'Kate Smith': 'Desarrollo del personaje Kate Smith para un videojuego.',
  'Desarrollo De Personajes': 'Exploración de colores y variantes durante el desarrollo de un personaje.',
  'Kate Smith Poses': 'Exploración de poses y variantes durante el desarrollo del personaje Kate Smith.',
  'Viaje Al Centro De La Celula': 'Diseño de varios personajes para la obra "Viaje al centro de la célula".',
};

const captionOverridesEn: Record<string, string> = {
  'Banshee 1': 'Character design for Banshee.',
  'Banshee 2': 'Exploration of variants, poses and facial expressions for Banshee.',
  'Lumo': 'Character development for Lumo for the book "¿Qué hago con este enfado?".',
  'Noah': 'Character development for Noah for the book "¿Qué hago con este enfado?".',
  'Kate Smith': 'Character development for Kate Smith for a video game.',
  'Desarrollo De Personajes': 'Color and variant exploration during character development.',
  'Kate Smith Poses': 'Pose and variant exploration during the development of Kate Smith.',
  'Viaje Al Centro De La Celula': 'Design of several characters for "Viaje al centro de la célula".',
};

const formatTitle = (path: string) => {
  const fileName = path.split('/').pop() ?? 'concept-art';
  return fileName
    .replace(/\.[^.]+$/, '')
    .replace(/^\d+[-_\s]*/, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
};

const concepts = Object.entries(imageModules)
  .map(([path, module]) => {
    const title = formatTitle(path);

    return {
      image: module.default,
      title,
      caption: captionOverrides[title] ?? `Concept art titulado ${title}.`,
      captionEn: captionOverridesEn[title] ?? `Concept art titled ${title}.`,
    };
  })
  .sort((a, b) => a.title.localeCompare(b.title));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Galería de concept art con exploraciones visuales, escenarios, personajes y desarrollo de ideas."
      data-i18n-content-es="Galería de concept art con exploraciones visuales, escenarios, personajes y desarrollo de ideas."
      data-i18n-content-en="Concept art gallery with visual explorations, environments, characters and idea development."
    />
    <meta name="robots" content="index, follow" />
    <title data-i18n-es="Concept Art | Portfolio de Ilustración" data-i18n-en="Concept Art | Illustration Portfolio">Concept Art | Portfolio de Ilustración</title>
  </head>
  <body>
    <SiteHeader currentPath="/concept-art" />

    <main>
      <section class="mx-auto max-w-7xl px-5 py-16 text-center sm:px-8 lg:py-24" aria-labelledby="gallery-title">
        <p class="text-sm font-black uppercase tracking-[0.32em] text-[#d95c45]" data-i18n-es="Galería" data-i18n-en="Gallery">Galería</p>
        <h1 id="gallery-title" class="mx-auto mt-4 max-w-4xl font-serif text-5xl font-black leading-[0.95] tracking-tight text-[#231f20] sm:text-6xl lg:text-7xl">
          Concept Art
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-[#59433b]" data-i18n-es="Una muestra de procesos visuales donde desarrollo personajes, escenarios e ideas, explorando formas, expresiones y estilos antes de llegar a una propuesta final." data-i18n-en="A selection of visual processes where I develop characters, environments and ideas, exploring shapes, expressions and styles before reaching a final proposal.">
          Una muestra de procesos visuales donde desarrollo personajes, escenarios e ideas, explorando formas, expresiones y estilos antes de llegar a una propuesta final.
        </p>
      </section>

      <FloatingIllustrationGallery
        images={concepts}
        ariaLabel="Listado de concept art"
        ariaLabelEn="Concept art list"
        emptyDirectory="src/assets/concept-art"
        emptyTitle="Todavía no hay concept art"
        emptyTitleEn="There is no concept art yet"
        itemLabel="concept art"
        unframed
      />
    </main>

    <SiteFooter />
  </body>
</html>
