---
import FloatingIllustrationGallery from '../components/FloatingIllustrationGallery.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import type { ImageMetadata } from 'astro';
import '../styles/global.css';

type ImageModule = { default: ImageMetadata };

const imageModules = import.meta.glob<ImageModule>('../assets/illustration/*.{jpg,jpeg,png,webp,avif,gif,svg}', {
  eager: true,
});

const captionOverrides: Record<string, string> = {
  'Alice In Wonderland': 'Portada para la famosa novela de Lewis Carroll, Alicia en el País de las Maravillas.',
  'Byler': 'Fan-art de Will Byers y Mike Wheeler, personajes de la serie Stranger Things.',
  'Kate Smith Room': 'Habitación del personaje ficticio Kate Smith.',
  'Moon Space': '',
  'Picnic': '',
  'Piplup & Oshawott': 'Piplup y Oshawott, disfrutando de un baño juntos.',
};

const captionOverridesEn: Record<string, string> = {
  'Alice In Wonderland': 'Cover for Lewis Carroll\'s famous novel, Alice in Wonderland.',
  'Byler': 'Fan art of Will Byers and Mike Wheeler, characters from Stranger Things.',
  'Kate Smith Room': 'Room for the fictional character Kate Smith.',
  'Moon Space': '',
  'Picnic': '',
  'Piplup & Oshawott': 'Piplup and Oshawott enjoying a bath together.',
};

const formatTitle = (path: string) => {
  const fileName = path.split('/').pop() ?? 'ilustracion';
  return fileName
    .replace(/\.[^.]+$/, '')
    .replace(/^\d+[-_\s]*/, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
};

const illustrations = await Promise.all(
  Object.entries(imageModules).map(([path, module]) => {
    const title = formatTitle(path);

    return {
      image: module.default,
      title,
      caption: captionOverrides[title] ?? `Ilustración titulada ${title}.`,
      captionEn: captionOverridesEn[title] ?? `Illustration titled ${title}.`,
    };
  })
).then((items) => items.sort((a, b) => a.title.localeCompare(b.title)));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Galería de ilustraciones personales con trabajos seleccionados de portfolio."
      data-i18n-content-es="Galería de ilustraciones personales con trabajos seleccionados de portfolio."
      data-i18n-content-en="Gallery of selected personal illustration work for the portfolio."
    />
    <meta name="robots" content="index, follow" />
    <title data-i18n-es="Ilustraciones | Portfolio de Ilustración" data-i18n-en="Illustrations | Illustration Portfolio">Ilustraciones | Portfolio de Ilustración</title>
  </head>
  <body>
    <SiteHeader currentPath="/illustration" />

    <main>
      <section class="mx-auto max-w-7xl px-5 py-16 text-center sm:px-8 lg:py-24" aria-labelledby="gallery-title">
        <p class="text-sm font-black uppercase tracking-[0.32em] text-[#d95c45]" data-i18n-es="Galería" data-i18n-en="Gallery">Galería</p>
        <h1 id="gallery-title" class="mx-auto mt-4 max-w-4xl font-serif text-5xl font-black leading-[0.95] tracking-tight text-[#231f20] sm:text-6xl lg:text-7xl" data-i18n-es="Ilustraciones" data-i18n-en="Illustrations">
          Ilustraciones
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-[#59433b]" data-i18n-es="Una selección de ilustraciones en las que exploro la narrativa visual, el color y la creación de personajes para dar forma a distintos mundos e historias." data-i18n-en="A selection of illustrations where I explore visual storytelling, color and character creation to shape different worlds and stories.">
          Una selección de ilustraciones en las que exploro la narrativa visual, el color y la creación de personajes para dar forma a distintos mundos e historias.
        </p>
      </section>

      <FloatingIllustrationGallery images={illustrations} unframed />
    </main>

    <SiteFooter />
  </body>
</html>
