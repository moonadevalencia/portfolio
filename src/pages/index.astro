        </div>
      </section> -->

    </main>

    <SiteFooter />

    <script>
      const scroller = document.querySelector('[data-project-scroll]');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (scroller instanceof HTMLElement && !reduceMotion) {
        let lastTime = performance.now();
        let pausedUntil = 0;

        const pauseBriefly = () => {
          pausedUntil = performance.now() + 1800;
        };

        scroller.addEventListener('pointerdown', pauseBriefly, { passive: true });
        scroller.addEventListener('wheel', pauseBriefly, { passive: true });
        scroller.addEventListener('keydown', pauseBriefly);

        const move = (time: number) => {
          const delta = Math.min(time - lastTime, 32);
          lastTime = time;

          if (time > pausedUntil) {
            const waveSpeed = 0.018 + Math.sin(time / 1300) * 0.01;
            scroller.scrollLeft += delta * waveSpeed;

            if (scroller.scrollLeft >= scroller.scrollWidth - scroller.clientWidth - 1) {
              scroller.scrollTo({ left: 0, behavior: 'smooth' });
            }
          }

          requestAnimationFrame(move);
        };

        requestAnimationFrame(move);
      }
    </script>
  </body>
</html>
