---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import profileImage from '../assets/img/pfp.webp';

type ImageModule = { default: ImageMetadata };

const projectCoverModules = import.meta.glob<ImageModule>('../assets/img/*.{jpg,jpeg,png,webp,avif,gif,svg}', {
  eager: true,
});

const getProjectCover = (fileName: string) => {
  // Mantener portadas como assets locales para poder optimizarlas con <Image />.
  return projectCoverModules[`../assets/img/${fileName}`]?.default;
};

const projects = [
  {
    title: 'Alice in Wonderland',
    category: 'Ilustración',
    gradient: 'from-[#ffad8f] via-[#ffd36e] to-[#fff7bf]',
    cover: getProjectCover('alicia.webp'),
  },
  {
    title: 'Kate Smith',
    category: 'Diseño de Personajes',
    gradient: 'from-[#7dd3fc] via-[#c4b5fd] to-[#fbcfe8]',
    cover: getProjectCover('kate-smith2.webp'),
  },
  {
    title: 'Noah y Lumo',
    category: 'Ilustración',
    gradient: 'from-[#fca5a5] via-[#fdba74] to-[#86efac]',
    cover: getProjectCover('Pagina_10.webp'),
  },
  {
    title: 'Huellas del vacío',
    category: 'Editorial',
    gradient: 'from-[#fde68a] via-[#f0abfc] to-[#a7f3d0]',
    cover: getProjectCover('portfolio.webp'),
  },
  {
    title: 'Piplup y Oshawott',
    category: 'Proyecto personal',
    gradient: 'from-[#bbf7d0] via-[#93c5fd] to-[#ddd6fe]',
    cover: getProjectCover('pokemon.webp'),
  },
  {
    title: 'Byler',
    category: 'Diseño de Personajes',
    gradient: 'from-[#fed7aa] via-[#fecdd3] to-[#e9d5ff]',
    cover: getProjectCover('byler.jpg'),
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Portfolio personal de ilustración, diseño gráfico, character design, visual development y proyectos editoriales."
