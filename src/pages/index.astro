---
import '../styles/global.css';

const navigation = [
  { label: 'Home', href: '/' },
  { label: 'Illustration', href: '/illustration' },
  { label: 'Concept Art', href: '/concept-art' },
  { label: 'Editorial', href: '#editorial' },
  { label: 'Contact', href: '#contact' },
];

const projects = [
  {
    title: 'Sueños botánicos',
    category: 'Illustration',
    gradient: 'from-[#ffad8f] via-[#ffd36e] to-[#fff7bf]',
  },
  {
    title: 'Mensajera lunar',
    category: 'Character Design',
    gradient: 'from-[#7dd3fc] via-[#c4b5fd] to-[#fbcfe8]',
  },
  {
    title: 'Mañana de mercado',
    category: 'Visual Development',
    gradient: 'from-[#fca5a5] via-[#fdba74] to-[#86efac]',
  },
  {
    title: 'Atlas diminuto',
    category: 'Editorial',
    gradient: 'from-[#fde68a] via-[#f0abfc] to-[#a7f3d0]',
  },
  {
    title: 'Notas del bosque',
    category: 'Proyecto personal',
    gradient: 'from-[#bbf7d0] via-[#93c5fd] to-[#ddd6fe]',
  },
  {
    title: 'Habitaciones al sol',
    category: 'Illustration',
    gradient: 'from-[#fed7aa] via-[#fecdd3] to-[#e9d5ff]',
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Portfolio personal de ilustración, diseño gráfico, character design, visual development y proyectos editoriales."
    />
    <meta name="robots" content="index, follow" />
    <title>Portfolio de Ilustración y Diseño Gráfico</title>
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-[#231f20]/10 bg-[#fffaf2]/85 backdrop-blur-xl">
      <nav
        class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-5 px-5 py-5 text-center sm:px-8 lg:flex-row lg:text-left"
        aria-label="Navegación principal"
      >
        <a
          href="/"
          class="font-serif text-2xl font-black tracking-tight text-[#231f20] transition hover:text-[#d95c45]"
          aria-label="Ir al inicio"
        >
          Nombre Artista
        </a>
        <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-3 text-sm font-bold uppercase tracking-[0.16em] text-[#59433b]">
          {
            navigation.map((item) => (
              <li>
                <a class="transition hover:text-[#d95c45] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main>
      <section class="mx-auto grid min-h-[calc(100vh-6rem)] max-w-7xl place-items-center px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="hero-title">
        <div class="grid w-full items-center gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
          <figure class="mx-auto w-full max-w-sm lg:mx-0">
            <div class="relative aspect-[4/5] overflow-hidden rounded-[2.5rem] border-4 border-[#231f20] bg-[#ffd36e] p-4 shadow-[18px_18px_0_#231f20]">
              <div
                class="flex h-full items-center justify-center rounded-[1.8rem] bg-gradient-to-br from-[#ffad8f] via-[#f7d7ff] to-[#9bd5ff] text-center"
                role="img"
                aria-label="Espacio reservado para una foto de perfil de la artista"
              >
                <div class="rounded-full border-4 border-[#231f20] bg-[#fffaf2]/85 px-8 py-7 shadow-lg">
                  <span class="block text-5xl font-black" aria-hidden="true">Foto</span>
                  <span class="mt-3 block text-xs font-black uppercase tracking-[0.28em] text-[#59433b]">Perfil</span>
                </div>
              </div>
            </div>
            <figcaption class="sr-only">Placeholder para añadir una fotografía de perfil.</figcaption>
          </figure>

          <article class="mx-auto max-w-2xl text-center lg:mx-0 lg:text-left">
            <p class="mb-4 text-sm font-black uppercase tracking-[0.32em] text-[#d95c45]">Illustration · Graphic Design</p>
            <h1 id="hero-title" class="font-serif text-5xl font-black leading-[0.95] tracking-tight text-[#231f20] sm:text-6xl lg:text-7xl">
              Portfolio visual para mundos dibujados con intención.
            </h1>
            <p class="mt-7 text-lg leading-8 text-[#59433b] sm:text-xl">
              Soy una ilustradora y diseñadora gráfica enfocada en construir personajes, atmósferas y piezas editoriales con una mirada cálida, narrativa y expresiva. Este espacio reúne proyectos personales, exploraciones visuales y trabajos seleccionados.
            </p>
            <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row lg:justify-start">
              <a
                href="#project-highlights"
                class="rounded-full bg-[#231f20] px-7 py-4 text-sm font-black uppercase tracking-[0.18em] text-white shadow-[7px_7px_0_#ee8d73] transition hover:-translate-y-1 hover:shadow-[10px_10px_0_#ee8d73] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#231f20]"
              >
                Ver proyectos
              </a>
              <a
                href="#contact"
                class="rounded-full border-2 border-[#231f20] bg-[#fffaf2] px-7 py-4 text-sm font-black uppercase tracking-[0.18em] text-[#231f20] transition hover:-translate-y-1 hover:bg-[#ffd36e] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#231f20]"
              >
                Contacto
              </a>
            </div>
          </article>
        </div>
      </section>

      <section id="project-highlights" class="mx-auto max-w-7xl px-5 pb-20 sm:px-8 lg:pb-28" aria-labelledby="projects-title">
        <div class="mx-auto mb-8 max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[0.32em] text-[#d95c45]">Trabajo personal</p>
          <h2 id="projects-title" class="mt-3 font-serif text-4xl font-black tracking-tight text-[#231f20] sm:text-5xl">
            Proyectos que se deslizan como una ola
          </h2>
          <p class="mt-5 text-base leading-7 text-[#59433b]">
            Una selección horizontal para explorar trabajos destacados. Puedes moverla manualmente o dejar que avance lentamente.
          </p>
        </div>

        <div
          class="project-scroll overflow-x-auto overscroll-x-contain rounded-[2rem] border-2 border-[#231f20]/15 bg-white/45 px-4 py-8 shadow-inner sm:px-7"
          data-project-scroll
          tabindex="0"
          aria-label="Galería horizontal de proyectos personales"
        >
          <ul class="flex w-max gap-5 pr-4 sm:gap-7">
            {
              projects.map((project) => (
                <li class="wave-card w-[16rem] shrink-0 sm:w-[20rem]">
                  <article class="group overflow-hidden rounded-[2rem] border-3 border-[#231f20] bg-[#fffaf2] shadow-[9px_9px_0_#231f20] transition duration-300 hover:-translate-y-2 hover:shadow-[13px_13px_0_#231f20]">
                    <div class={`aspect-[4/5] bg-gradient-to-br ${project.gradient} p-5`} aria-hidden="true">
                      <div class="grid h-full place-items-center rounded-[1.4rem] border-2 border-[#231f20]/70 bg-white/25">
                        <span class="font-serif text-6xl font-black text-[#231f20]/80 transition group-hover:scale-110">{project.title.slice(0, 1)}</span>
                      </div>
                    </div>
                    <div class="p-5 text-left">
                      <p class="text-xs font-black uppercase tracking-[0.24em] text-[#d95c45]">{project.category}</p>
                      <h3 class="mt-2 font-serif text-2xl font-black text-[#231f20]">{project.title}</h3>
                    </div>
                  </article>
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    </main>

    <footer id="contact" class="border-t border-[#231f20]/10 px-5 py-10 text-center text-sm text-[#59433b] sm:px-8">
      <p><strong class="text-[#231f20]">Nombre Artista</strong> · Portfolio de ilustración y diseño gráfico.</p>
    </footer>

    <script>
      const scroller = document.querySelector('[data-project-scroll]');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (scroller instanceof HTMLElement && !reduceMotion) {
        let lastTime = performance.now();
        let pausedUntil = 0;

        const pauseBriefly = () => {
          pausedUntil = performance.now() + 1800;
        };

        scroller.addEventListener('pointerdown', pauseBriefly, { passive: true });
        scroller.addEventListener('wheel', pauseBriefly, { passive: true });
        scroller.addEventListener('keydown', pauseBriefly);

        const move = (time: number) => {
          const delta = Math.min(time - lastTime, 32);
          lastTime = time;

          if (time > pausedUntil) {
            const waveSpeed = 0.018 + Math.sin(time / 1300) * 0.01;
            scroller.scrollLeft += delta * waveSpeed;

            if (scroller.scrollLeft >= scroller.scrollWidth - scroller.clientWidth - 1) {
              scroller.scrollTo({ left: 0, behavior: 'smooth' });
            }
          }

          requestAnimationFrame(move);
        };

        requestAnimationFrame(move);
      }
    </script>
  </body>
</html>
