---
import FloatingIllustrationGallery from '../../components/FloatingIllustrationGallery.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import type { ImageMetadata } from 'astro';
import '../../styles/global.css';

type ImageModule = { default: ImageMetadata };

const galleryModules = import.meta.glob<ImageModule>(
  '../../assets/editorial/viaje-al-centro-de-la-celula/*.{jpg,jpeg,png,webp,avif,gif,svg}',
  { eager: true },
);

const formatTitle = (path: string) => {
  const fileName = path.split('/').pop() ?? 'imagen-editorial';
  return fileName
    .replace(/\.[^.]+$/, '')
    .replace(/^\d+[-_\s]*/, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
};

const galleryImages = Object.entries(galleryModules)
  .map(([path, module]) => {
    const title = formatTitle(path);

    return {
      image: module.default,
      title,
      caption: `Imagen del proyecto editorial Viaje al centro de la célula: ${title}.`,
      captionEn: `Image from the editorial project Viaje al centro de la célula: ${title}.`,
    };
  })
  .sort((a, b) => a.title.localeCompare(b.title));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Detalle del proyecto editorial Viaje al centro de la célula, con explicación conceptual y galería de imágenes."
      data-i18n-content-es="Detalle del proyecto editorial Viaje al centro de la célula, con explicación conceptual y galería de imágenes."
      data-i18n-content-en="Detail page for the editorial project Viaje al centro de la célula, with concept explanation and image gallery."
    />
    <meta name="robots" content="index, follow" />
    <title data-i18n-es="Viaje al centro de la célula | Editorial" data-i18n-en="Viaje al centro de la célula | Editorial">Viaje al centro de la célula | Editorial</title>
  </head>
  <body>
    <SiteHeader currentPath="/editorial" />

    <main>
      <section class="mx-auto max-w-5xl px-5 py-16 text-center sm:px-8 lg:py-24" aria-labelledby="project-title">
        <article class="mx-auto rounded-[2rem] border-3 border-[#231f20] bg-[#fffaf2]/85 p-6 shadow-[10px_10px_0_#ee8d73] sm:p-8 lg:p-10">
          <p class="text-sm font-black uppercase tracking-[0.32em] text-[#d95c45]" data-i18n-es="Proyecto editorial" data-i18n-en="Editorial project">Proyecto editorial</p>
          <h1 id="project-title" class="mx-auto mt-3 max-w-4xl font-serif text-5xl font-black leading-[0.95] tracking-tight text-[#231f20] sm:text-6xl">Viaje al centro de la célula</h1>
          <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-[#59433b]" data-i18n-es="Proyecto editorial de divulgación visual realizado para el Centro de Biología Molecular (CBM) Severo Ochoa. A través de ilustraciones narrativas y un lenguaje gráfico claro y accesible, el proyecto acerca conceptos científicos al público joven, transformando el mundo celular en una experiencia visual más cercana y comprensible." data-i18n-en="Visual science communication editorial project created for the Severo Ochoa Molecular Biology Center (CBM). Through narrative illustrations and a clear, accessible graphic language, the project brings scientific concepts closer to young audiences, turning the cellular world into a more approachable visual experience.">
            Proyecto editorial de divulgación visual realizado para el Centro de Biología Molecular (CBM) Severo Ochoa. A través de ilustraciones narrativas y un lenguaje gráfico claro y accesible, el proyecto acerca conceptos científicos al público joven, transformando el mundo celular en una experiencia visual más cercana y comprensible.
          </p>
          <a href="/editorial" class="mt-8 inline-flex rounded-full border-2 border-[#231f20] bg-[#ffd36e] px-7 py-4 text-sm font-black uppercase tracking-[0.18em] text-[#231f20] transition hover:-translate-y-1 hover:bg-[#ffad8f] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]">
            <span data-i18n-es="Volver" data-i18n-en="Back">Volver</span>
          </a>
        </article>
      </section>

      <FloatingIllustrationGallery
        images={galleryImages}
        ariaLabel="Galería del proyecto Viaje al centro de la célula"
        ariaLabelEn="Gallery for the project Viaje al centro de la célula"
        emptyDirectory="src/assets/editorial/viaje-al-centro-de-la-celula"
        emptyTitle="Todavía no hay imágenes para este proyecto"
        emptyTitleEn="There are no images for this project yet"
        itemLabel="imagen editorial"
        itemLabelEn="editorial image"
        unframed
        showCaptions={false}
      />
    </main>
  </body>
</html>
