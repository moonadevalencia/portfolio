---
import FloatingIllustrationGallery from '../../components/FloatingIllustrationGallery.astro';
import type { ImageMetadata } from 'astro';
import '../../styles/global.css';

type ImageModule = { default: ImageMetadata };

const navigation = [
  { label: 'Inicio', href: '/' },
  { label: 'Ilustraciones', href: '/illustration' },
  { label: 'Concept Art', href: '/concept-art' },
  { label: 'Editorial', href: '/editorial' },
  { label: 'Contacto', href: '/contact' },
];

const galleryModules = import.meta.glob<ImageModule>(
  '../../assets/editorial/viaje-al-centro-de-la-celula/*.{jpg,jpeg,png,webp,avif,gif,svg}',
  { eager: true },
);

const formatTitle = (path: string) => {
  const fileName = path.split('/').pop() ?? 'imagen-editorial';
  return fileName
    .replace(/\.[^.]+$/, '')
    .replace(/^\d+[-_\s]*/, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
};

const galleryImages = Object.entries(galleryModules)
  .map(([path, module]) => {
    const title = formatTitle(path);

    return {
      image: module.default,
      title,
      caption: `Imagen del proyecto editorial Viaje al centro de la célula: ${title}.`,
    };
  })
  .sort((a, b) => a.title.localeCompare(b.title));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Detalle del proyecto editorial Viaje al centro de la célula, con explicación conceptual y galería de imágenes." />
    <meta name="robots" content="index, follow" />
    <title>Viaje al centro de la célula | Editorial</title>
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-[#231f20]/10 bg-[#fffaf2]/85 backdrop-blur-xl">
      <nav class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-5 px-5 py-5 text-center sm:px-8 lg:flex-row lg:text-left" aria-label="Navegación principal">
        <a href="/" class="font-serif text-2xl font-black tracking-tight text-[#231f20] transition hover:text-[#d95c45]" aria-label="Ir al inicio">Moona</a>
        <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-3 text-sm font-bold uppercase tracking-[0.16em] text-[#59433b]">
          {
            navigation.map((item) => (
              <li>
                <a class="transition hover:text-[#d95c45] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main>
      <section class="mx-auto max-w-5xl px-5 py-16 text-center sm:px-8 lg:py-24" aria-labelledby="project-title">
        <article class="mx-auto rounded-[2rem] border-3 border-[#231f20] bg-[#fffaf2]/85 p-6 shadow-[10px_10px_0_#ee8d73] sm:p-8 lg:p-10">
          <p class="text-sm font-black uppercase tracking-[0.32em] text-[#d95c45]">Proyecto editorial</p>
          <h1 id="project-title" class="mx-auto mt-3 max-w-4xl font-serif text-5xl font-black leading-[0.95] tracking-tight text-[#231f20] sm:text-6xl">Viaje al centro de la célula</h1>
          <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-[#59433b]">
            Proyecto editorial de divulgación visual realizado para el Centro de Biología Molecular (CBM) Severo Ochoa. A través de ilustraciones narrativas y un lenguaje gráfico claro y accesible, el proyecto acerca conceptos científicos al público joven, transformando el mundo celular en una experiencia visual más cercana y comprensible.
          </p>
          <a href="/editorial" class="mt-8 inline-flex rounded-full border-2 border-[#231f20] bg-[#ffd36e] px-7 py-4 text-sm font-black uppercase tracking-[0.18em] text-[#231f20] transition hover:-translate-y-1 hover:bg-[#ffad8f] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]">
            Volver
          </a>
        </article>
      </section>

      <FloatingIllustrationGallery
        images={galleryImages}
        ariaLabel="Galería del proyecto Viaje al centro de la célula"
        emptyDirectory="src/assets/editorial/viaje-al-centro-de-la-celula"
        emptyTitle="Todavía no hay imágenes para este proyecto"
        itemLabel="imagen editorial"
        unframed
        showCaptions={false}
      />
    </main>
  </body>
</html>
