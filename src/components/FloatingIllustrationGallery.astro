---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type FloatingImage = {
  image: ImageMetadata;
  title: string;
  caption: string;
};

type Props = {
  images: FloatingImage[];
  ariaLabel?: string;
  emptyDirectory?: string;
  emptyTitle?: string;
  itemLabel?: string;
};

const {
  images,
  ariaLabel = 'Listado de ilustraciones',
  emptyDirectory = 'src/assets/illustration',
  emptyTitle = 'Todavía no hay ilustraciones',
  itemLabel = 'ilustración',
} = Astro.props;
---

<section class="mx-auto max-w-7xl px-5 pb-20 sm:px-8 lg:pb-28" aria-label={ariaLabel}>
  {
    images.length > 0 ? (
      <ul class="columns-1 gap-7 sm:columns-2 lg:columns-3 [column-fill:_balance]">
        {images.map((image, index) => (
          <li class="mb-7 break-inside-avoid">
            <button
              type="button"
              class="group block w-full cursor-zoom-in rounded-[1.4rem] transition duration-300 hover:-translate-y-2 hover:scale-[1.025] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d95c45]"
              data-floating-gallery-button
              data-index={index}
              aria-label={`Ampliar ${itemLabel} ${image.title}`}
            >
              <Image
                src={image.image}
                width={900}
                alt={image.title}
                loading={index < 3 ? 'eager' : 'lazy'}
                decoding="async"
                class="h-auto w-full rounded-[1.4rem] border-3 border-[#231f20] object-contain shadow-[8px_8px_0_#231f20] transition duration-300 group-hover:shadow-[12px_12px_0_#ee8d73]"
              />
            </button>
          </li>
        ))}
      </ul>
    ) : (
      <div class="px-6 py-16 text-center">
        <h2 class="font-serif text-3xl font-black text-[#231f20]">{emptyTitle}</h2>
        <p class="mx-auto mt-4 max-w-xl leading-7 text-[#59433b]">
          Añade imágenes en <code class="rounded bg-[#231f20]/10 px-2 py-1">{emptyDirectory}</code> y se mostrarán aquí automáticamente.
        </p>
      </div>
    )
  }
</section>

<dialog
  class="m-auto max-h-[92vh] w-[min(92vw,76rem)] overflow-hidden rounded-[2rem] border-3 border-[#231f20] bg-[#fffaf2] p-3 shadow-[14px_14px_0_#231f20] backdrop:bg-[#231f20]/65"
  data-floating-lightbox
  aria-label="Vista ampliada de ilustración"
>
  <figure>
    {
      images.map((image, index) => (
        <div data-floating-lightbox-panel data-index={index} hidden>
          <Image
            src={image.image}
            width={1600}
            alt={image.title}
            loading="lazy"
            decoding="async"
            class="max-h-[76vh] w-full rounded-[1.4rem] object-contain"
          />
          <figcaption class="px-2 pb-3 pt-5 text-center">
            <strong class="block font-serif text-2xl font-black text-[#231f20]">{image.title}</strong>
            <span class="mx-auto mt-2 block max-w-3xl text-base leading-7 text-[#59433b]">{image.caption}</span>
          </figcaption>
        </div>
      ))
    }
  </figure>
</dialog>

<script>
  const lightbox = document.querySelector('[data-floating-lightbox]');
  const galleryButtons = document.querySelectorAll('[data-floating-gallery-button]');
  const lightboxPanels = document.querySelectorAll('[data-floating-lightbox-panel]');

  if (lightbox instanceof HTMLDialogElement) {
    let activePanel: HTMLElement | undefined;
    let previousBodyOverflow = '';

    const lockPageScroll = () => {
      previousBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';
    };

    const restorePageScroll = () => {
      document.body.style.overflow = previousBodyOverflow;
    };

    const hideActivePanel = () => {
      if (activePanel) {
        activePanel.hidden = true;
        activePanel = undefined;
      }
    };

    galleryButtons.forEach((button) => {
      if (!(button instanceof HTMLElement)) return;

      button.addEventListener('click', () => {
        const index = button.dataset.index;
        const panel = Array.from(lightboxPanels).find(
          (item): item is HTMLElement => item instanceof HTMLElement && item.dataset.index === index,
        );

        if (!panel) return;

        hideActivePanel();
        panel.hidden = false;
        activePanel = panel;
        lockPageScroll();
        lightbox.showModal();
      });
    });

    lightbox.addEventListener('click', (event) => {
      if (event.target === lightbox) {
        lightbox.close();
      }
    });

    lightbox.addEventListener('close', () => {
      hideActivePanel();
      restorePageScroll();
    });
  }
</script>
